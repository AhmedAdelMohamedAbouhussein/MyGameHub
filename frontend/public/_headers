# Global security headers for all routes
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  # !!! IMPORTANT: Updated with ngrok Backend URL !!!
  Content-Security-Policy: default-src 'none'; script-src 'self' https://accounts.google.com https://apis.google.com https://www.google.com; connect-src 'self' https://mariam-noncongruent-nonbeatifically.ngrok-free.dev https://api.rawg.io https://api.isthereanydeal.com https://accounts.google.com https://www.googleapis.com; img-src 'self' data: blob: https://res.cloudinary.com https://*.akamaihd.net https://*.rawg.io https://image.api.playstation.com https://i.ytimg.com https://lh3.googleusercontent.com https://www.gstatic.com; media-src 'self' https://*.akamaihd.net https://i.ytimg.com; frame-src https://open.spotify.com https://www.youtube.com https://accounts.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; base-uri 'self'; form-action 'self'; frame-ancestors 'none';

# Caching for index.html (never cache)
/index.html
  Cache-Control: no-store, no-cache, must-revalidate
  Expires: 0

# Aggressive caching for static assets in /assets/
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Caching for common root-level static files
/*.js
  Cache-Control: public, max-age=31536000, immutable
